# ==============================================================================
# RentGuard 360 - Frontend Environment Template
# ==============================================================================
# Copy this file to .env and fill in the values after CloudFormation deployment
# ==============================================================================

# =============================================================================
# API Gateway
# =============================================================================
# Get this from CloudFormation outputs or AWS Console -> API Gateway -> Stages
VITE_API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
VITE_CHECK_USER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# Cognito Configuration
# =============================================================================
# Get these from CloudFormation outputs or AWS Console -> Cognito -> User Pools
VITE_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_DOMAIN=XXXXXXXXX.auth.us-east-1.amazoncognito.com
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/
VITE_OAUTH_REDIRECT_OUT_URI=http://localhost:5173/

# =============================================================================
# AWS Region
# =============================================================================
VITE_AWS_REGION=us-east-1

# =============================================================================
# S3 Bucket (for contract uploads)
# =============================================================================
# Get this from CloudFormation outputs
VITE_S3_BUCKET=rentguard360-contracts-XXXXXXXXXXXX

# =============================================================================
# Stripe Payment Integration
# =============================================================================
# Get these from Stripe Dashboard -> Developers -> API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXX
# The URL of your C# Stripe Payment API (Lambda + API Gateway)
VITE_STRIPE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod

# =============================================================================
# How to get these values after deployment
# =============================================================================
# Run these commands in AWS CloudShell:
#
# aws cloudformation describe-stacks --stack-name RentGuard360 \
#   --query "Stacks[0].Outputs[?OutputKey=='ApiUrl'].OutputValue" --output text
#
# aws cloudformation describe-stacks --stack-name RentGuard360 \
#   --query "Stacks[0].Outputs[?OutputKey=='UserPoolId'].OutputValue" --output text
#
# aws cloudformation describe-stacks --stack-name RentGuard360 \
#   --query "Stacks[0].Outputs[?OutputKey=='UserPoolClientId'].OutputValue" --output text
#
# aws cloudformation describe-stacks --stack-name RentGuard360 \
#   --query "Stacks[0].Outputs[?OutputKey=='ContractsBucketName'].OutputValue" --output text
#
# aws apigateway get-api-keys --name-query "RentGuard360-CheckUserKey" \
#   --include-values --query "items[0].value" --output text
#
# aws cognito-idp describe-user-pool-domain --domain YOUR_DOMAIN_HERE \
#   --query "DomainDescription.CloudFrontDistribution" --output text
